{
	"name": "hestia",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"android": "EXPO_ATLAS=true expo run:android",
		"android:reset": "rm -rf android && expo prebuild --platform android --clean && expo run:android",
		"android:prebuild:clean": "rm -rf android && expo prebuild --platform android --clean",
		"android:build:apk": "bun run android:prebuild:clean && (cd android && ./gradlew assembleRelease)",
		"android:build:aab": "bun run android:prebuild:clean && (cd android && ./gradlew bundleRelease)",
		"start": "EXPO_ATLAS=true expo start",
		"prebuild": "expo prebuild",
		"lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
		"format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
		"update": "expo install --fix",
		"update:expo": "expo install expo@latest --fix"
	},
	"dependencies": {
		"@expo/vector-icons": "^15.0.3",
		"@react-native-async-storage/async-storage": "2.2.0",
		"@react-native-google-signin/google-signin": "^16.1.2",
		"@react-navigation/bottom-tabs": "^7.4.0",
		"@react-navigation/elements": "^2.6.3",
		"@react-navigation/native": "^7.1.8",
		"@rn-primitives/avatar": "^1.2.0",
		"@rn-primitives/slot": "^1.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"expo": "^55.0.8",
		"expo-application": "~55.0.10",
		"expo-auth-session": "~55.0.9",
		"expo-constants": "~55.0.9",
		"expo-crypto": "~55.0.10",
		"expo-device": "~55.0.10",
		"expo-font": "~55.0.4",
		"expo-haptics": "~55.0.9",
		"expo-image": "~55.0.6",
		"expo-linking": "~55.0.8",
		"expo-localization": "~55.0.9",
		"expo-notifications": "~55.0.13",
		"expo-router": "~55.0.7",
		"expo-secure-store": "~55.0.9",
		"expo-splash-screen": "~55.0.12",
		"expo-status-bar": "~55.0.4",
		"expo-symbols": "~55.0.5",
		"expo-system-ui": "~55.0.10",
		"expo-updates": "~55.0.15",
		"expo-web-browser": "~55.0.10",
		"i18next": "^25.9.0",
		"lucide-react-native": "^0.577.0",
		"nativewind": "^5.0.0-preview.3",
		"pocketbase": "^0.26.8",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-i18next": "^16.5.8",
		"react-native": "0.83.2",
		"react-native-css": "^3.0.6",
		"react-native-gesture-handler": "~2.30.0",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-sse": "^1.2.1",
		"react-native-web": "~0.21.0",
		"react-native-webview": "13.16.0",
		"react-native-worklets": "0.7.2",
		"tailwind-merge": "^3.5.0",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.2",
		"@types/react": "~19.2.10",
		"babel-preset-expo": "~55.0.8",
		"eslint": "^9.25.0",
		"eslint-config-expo": "~55.0.0",
		"postcss": "^8.5.8",
		"prettier-plugin-tailwindcss": "^0.5.11",
		"tailwindcss": "^4.2.2",
		"typescript": "~5.9.2"
	},
	"private": true,
	"trustedDependencies": [
		"unrs-resolver"
	],
	"overrides": {
		"lightningcss": "1.30.1"
	},
	"packageManager": "bun@1.3.10"
}